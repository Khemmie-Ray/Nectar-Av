# Copy to script/arbitrum.env and fill in the remaining wallet-specific values.
# This template is prepared for Arbitrum Sepolia.

# Common deploy settings
export RPC_URL=https://your-arbitrum-rpc
export PRIVATE_KEY=0xYourPrivateKey

# Arbitrum Sepolia
export EXPECTED_CHAIN_ID=421614
export LIT_EVM_CHAIN=arbitrumSepolia

# External protocol dependencies
export AAVE_POOL=0xBfC91D59fdAA134A4ED45f7B584cAf96D7792Eff
export USDC=0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d

# Set after deploying the Chainlink adapter
export VRF_MODULE=0x0000000000000000000000000000000000000000

# Chainlink VRF v2.5 config for Arbitrum Sepolia
export VRF_COORDINATOR=0x5CE8D5A2BC84beb22a398CCA51996F7930313D61
export VRF_KEY_HASH=0x1770bdc7eec7771f7ba4ffd640f34260d7f095b79c92d34a5b2551d6f6cfd2be
export VRF_SUBSCRIPTION_ID=0
export VRF_CALLBACK_GAS_LIMIT=500000
export VRF_REQUEST_CONFIRMATIONS=3
export VRF_NATIVE_PAYMENT=true

# Set after deploying the factory if you are running DeployChainlinkVRFModule.s.sol separately
export FACTORY=0xYourFactory

# Artifact service live mode
export ARTIFACT_SOURCE=live
export CHAIN_ID=421614
export NECTAR_FACTORY=0xYourFactory
export POOL_ADDRESS=0xYourPool
